# ReceiptIQ environment configuration
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file.

# Supabase project (Settings -> API)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google Cloud Vision API key (used for OCR)
GOOGLE_VISION_API_KEY=

# OpenAI API key (used for receipt understanding / extraction)
OPENAI_API_KEY=
# Model used for extraction (cheap + capable). Override if desired.
OPENAI_MODEL=gpt-4o-mini

# Default display currency (ISO 4217 code), e.g. KES, USD, NGN, UGX, TZS
DEFAULT_CURRENCY=KES
